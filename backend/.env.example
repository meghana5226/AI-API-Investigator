# App
PROJECT_NAME=AI API Investigator
ENVIRONMENT=development
DEBUG=true

# Security -- generate a real secret for production: openssl rand -hex 32
SECRET_KEY=change-this-secret-key-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_MINUTES=10080

# Database
DATABASE_URL=postgresql://postgres:postgres@db:5432/ai_api_investigator

# Redis
REDIS_URL=redis://redis:6379/0

# CORS (comma-separated in real env files handled by pydantic-settings JSON parsing;
# for docker-compose this is passed as a Python-list-looking string)
BACKEND_CORS_ORIGINS=["http://localhost:5173","http://localhost:3000","http://localhost"]

# Uploads
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=10

# AI / Vector store
CHROMA_PERSIST_DIR=chroma_data
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Which LLM backend to use: "ollama" (self-hosted, free, needs local compute)
# or "groq" (hosted, free tier, fast -- get a key at https://console.groq.com).
# For production/deployed environments without a GPU or beefy CPU, "groq" is
# strongly recommended.
LLM_PROVIDER=ollama

# Used only when LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://ollama:11434
# qwen2.5:7b gives the best answers but can take 1-3+ minutes per response
# on a CPU-only machine (no GPU). If AI responses are timing out or you'd
# rather have fast iteration while testing, switch to a smaller model --
# pull it first with: docker compose exec ollama ollama pull qwen2.5:1.5b
OLLAMA_MODEL=qwen2.5:7b

# Used only when LLM_PROVIDER=groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

AI_REQUEST_TIMEOUT_SECONDS=240

# Rate limiting
RATE_LIMIT_PER_MINUTE=60

# Pagination
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100
